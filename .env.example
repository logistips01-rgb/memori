# Supabase (obtenlos en: Project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe (obtenlos en: stripe.com/dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (obtenlo en: resend.com > API Keys)
RESEND_API_KEY=re_...

# URL base del proyecto
BASE_URL=https://memori.mlorente.es

# Google OAuth (para Supabase Auth - obtenlos en: console.cloud.google.com)
# Configúralos en: Supabase Dashboard > Authentication > Providers > Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
